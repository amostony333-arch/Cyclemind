{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "perps.html", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "logo.jpg", "use": "@vercel/static" },
    { "src": "main.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/app.js", "dest": "/app.js" },
    { "src": "/styles.css", "dest": "/styles.css" },
    { "src": "/logo.jpg", "dest": "/logo.jpg" },
    { "src": "/perps.html", "dest": "/perps.html" },
    { "src": "/perps", "dest": "/perps.html" },
    { "src": "/api/(.*)", "dest": "/main.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
